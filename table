-- 가격이 1000 이상인 상품
SELECT product_name FROM product WHERE price >= 1000
UNION
-- 가격이 500 이하인 상품
SELECT product_name FROM product WHERE price <= 500;

-- 중복 포함
SELECT product_name FROM product WHERE price >= 1000
UNION ALL
SELECT product_name FROM product WHERE price <= 500;

SELECT p.product_name, m.maker_name
FROM product p
INNER JOIN maker m
ON p.maker_id = m.maker_id;

SELECT p.product_name, m.maker_name
FROM product p
LEFT JOIN maker m
ON p.maker_id = m.maker_id;

SELECT *
FROM product
CROSS JOIN maker;