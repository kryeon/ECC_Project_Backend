-- 메이커 테이블
CREATE TABLE maker (
    maker_id CHAR(4) PRIMARY KEY,
    maker_name VARCHAR(30)
);

-- 상품 테이블
CREATE TABLE product (
    product_id INT AUTO_INCREMENT PRIMARY KEY,
    product_name VARCHAR(30),
    maker_id CHAR(4),
    price INT,
    FOREIGN KEY (maker_id) REFERENCES maker(maker_id)
);

